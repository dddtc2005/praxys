# vite-plugin-pwa@1.2.0's peer-range declares vite@3-7 but its code works
# fine with vite@8 (verified locally + in CI). Until the plugin publishes
# a peer-range bump, we install with legacy-peer-deps globally for this
# project so `npm install` in CI doesn't fail on the ERESOLVE.
legacy-peer-deps=true
