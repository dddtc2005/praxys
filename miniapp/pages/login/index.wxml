<view class="login-root {{themeClass}}">
  <!-- Brand mark — race flag PNG from docs/brand/assets, per § II
       of the brand guide. Wordmark uses nested <text> so "Praxys"
       reads as one run (no inter-letter flex gaps). -->
  <view class="login-brand">
    <image class="login-mark" src="/assets/brand/mark.png" mode="aspectFit" />
    <view class="login-wordmark">
      <text class="login-wordmark__text">Pra<text class="login-wordmark__accent">x</text>ys</text>
    </view>
    <text class="login-tagline">{{tr.tagline}}</text>
  </view>

  <block wx:if="{{stage === 'idle'}}">
    <text class="login-title">{{tr.welcomeBack}}</text>
    <text class="login-detail">{{tr.idleDetail}}</text>
    <button class="ts-button login-cta" bindtap="onSignInTap">{{tr.signInWeChat}}</button>
    <view class="login-newhere">
      <text class="login-newhere-label ts-muted">{{tr.newHere}}</text>
      <view class="login-signup-row" bindtap="onCopySignupUrl">
        <text class="login-signup-url ts-primary">praxys.run</text>
        <text class="login-signup-hint ts-muted">{{tr.tapToCopyUrl}}</text>
      </view>
    </view>
  </block>

  <block wx:elif="{{stage === 'loading'}}">
    <text class="login-title">{{tr.signingIn}}</text>
  </block>

  <block wx:elif="{{stage === 'error'}}">
    <text class="login-title ts-destructive">{{tr.signInFailed}}</text>
    <text class="login-detail">{{errorMessage}}</text>
    <button class="ts-button login-cta" bindtap="onRetry">{{tr.retry}}</button>
  </block>

  <!-- WeChat is unbound on the backend. The mini program is a "view +
       manage" companion; account creation lives on praxys.run. We show
       the link-to-existing-account form straight away, with a clear
       "new here? go to web" path next to it. -->
  <block wx:elif="{{stage === 'choose' || stage === 'link'}}">
    <text class="login-title">{{tr.linkTitle}}</text>
    <text class="login-detail">{{tr.linkDetail}}</text>
    <input
      class="ts-input login-input"
      type="text"
      placeholder="{{tr.emailPlaceholder}}"
      placeholder-style="color: #8b93a7;"
      value="{{linkEmail}}"
      bindinput="onLinkEmailInput"
    />
    <input
      class="ts-input login-input"
      password="{{true}}"
      placeholder="{{tr.passwordPlaceholder}}"
      placeholder-style="color: #8b93a7;"
      value="{{linkPassword}}"
      bindinput="onLinkPasswordInput"
    />
    <text wx:if="{{linkError}}" class="login-error ts-destructive">{{linkError}}</text>
    <button
      class="ts-button login-cta"
      loading="{{linkSubmitting}}"
      bindtap="onLinkSubmit"
    >{{tr.linkAction}}</button>

    <view class="login-newhere">
      <text class="login-newhere-label ts-muted">{{tr.newHere}}</text>
      <view class="login-signup-row" bindtap="onCopySignupUrl">
        <text class="login-signup-url ts-primary">praxys.run</text>
        <text class="login-signup-hint ts-muted">{{tr.tapToCopyUrl}}</text>
      </view>
    </view>
  </block>
</view>
